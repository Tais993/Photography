@startuml C3_Application
!include <C4/C4_Component>

title C3 - Component Diagram - Application

LAYOUT_LEFT_RIGHT()

Person(user, "Photographer")

Container_Boundary(presentation, "Presentation Layer") {
    Container(cli, "CLI Application", "C# / .NET", "Command-line interface")
    Container(web, "Web Application", "ASP.NET Razor Pages", "Visual interface for projects, images, and selections")
}

Container_Boundary(application, "Application / Logic Layer") {
    Component(services, "Services", "C#", "Contains the application services / logic")
}

Container_Boundary(domain, "Domain Layer") {
    Component(domainEntities, "Domain Entities", "C#", "Contains entities used by the application")
}

Container_Boundary(infra, "Infrastructure Layer") {
    Component(repositories, "Repositories", "C#", "Reads and writes database data")
    Component(fileSystem, "File System Component", "C#", "Reads folders, searches files, writes project.info, and copies images")
    Component(externalTools, "External Tool Components", "C#", "Handles communication with external tools such as IrfanView")
}

ContainerDb(database, "PostgreSQL Database", "SQL", "Stores projects, images, metadata, subprojects, and selection sessions")
System_Ext(fs, "File System", "Project folders and image files")
System_Ext(irfanview, "IrfanView", "External image viewer")

Rel(user, cli, "Executes commands")
Rel(user, web, "Browses and selects images")

Rel(cli, services, "Delegates logic")
Rel(web, services, "Delegates logic")

Rel_R(services, domainEntities, "Works with")
Rel(services, repositories, "Requests data through")
Rel(services, fileSystem, "Requests file operations through")
Rel(services, externalTools, "Requests external tools through")

Rel(repositories, database, "Reads/writes")
Rel(fileSystem, fs, "Reads/writes")
Rel(externalTools, irfanview, "Opens images and retrieves current image")

@enduml