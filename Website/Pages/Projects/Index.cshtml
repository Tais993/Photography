@page
@using Domain.entities
@model IndexModel

@{
ViewData["Title"] = "Projects";
}

<div class="page-body">
    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <div class="page-pretitle">
                    Picture Project Tool
                </div>
                <h2 class="page-title">
                    Projects
                </h2>
                <div class="text-muted mt-1">
                    Browse your photography projects and open one to manage images or selections.
                </div>
            </div>

            <div class="col-auto ms-auto d-flex gap-2 align-items-center">
                <span class="badge bg-blue-lt">
                    <i class="ti ti-folders me-1"></i>
                    @Model.ProjectPage.TotalItems out of @Model.ProjectCount project(s)
                </span>

                <a asp-page="./Index"
                   asp-route-ShowCreateProjectModal="true"
                   class="btn btn-primary">
                    <i class="ti ti-plus me-2"></i>
                    Add project
                </a>
            </div>
        </div>
    </div>

    <div class="row row-cards mt-3">

        <div class="col-12">
            <form method="get" class="card">
                <div class="card-body">
                    <label class="form-label" asp-for="Search">Search projects</label>

                    <div class="row g-2">
                        @if (Model.SelectedProjectId is not null)
                        {
                        <input type="hidden" asp-for="SelectedProjectId"/>
                        }

                        <input type="hidden" asp-for="ProjectPageNumber"/>

                        <div class="col-md-2">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="Search"
                                       class="form-control"
                                       placeholder="Search by name..."/>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="ProjectPath"
                                       class="form-control"
                                       placeholder="Search by path..."/>
                            </div>
                        </div>

                        <div class="col-auto">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="ProjectId"
                                       class="form-control w-auto"
                                       type="text"
                                       inputmode="numeric"
                                       pattern="[0-9]*"
                                       size="7"
                                       placeholder="ID"/>
                            </div>
                        </div>

                        <div class="col-auto">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="ParentProjectId"
                                       class="form-control w-auto"
                                       type="text"
                                       inputmode="numeric"
                                       pattern="[0-9]*"
                                       size="7"
                                       placeholder="parent ID"/>
                            </div>
                        </div>

                        <div class="col-auto">
                            <input asp-for="EventDate"
                                   type="date"
                                   asp-format="{0:yyyy-MM-dd}"
                                   class="form-control"/>
                        </div>

                        <div class="col-auto">
                            <select asp-for="ProjectPageSize"
                                    class="form-select"
                                    onchange="document.querySelector('[name=ProjectPageNumber]').value = 1; this.form.submit();">
                                <option value="20">20 per page</option>
                                <option value="60">60 per page</option>
                                <option value="120">120 per page</option>
                                <option value="240">240 per page</option>
                            </select>
                        </div>

                        <div class="col-auto">
                            <button type="submit"
                                    class="btn btn-primary"
                                    onclick="document.querySelector('[name=ProjectPageNumber]').value = 1">
                                <i class="ti ti-search me-2"></i>
                                Search
                            </button>
                        </div>

                        <div class="col-auto">
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                Reset
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <div>
                        <h3 class="card-title">All projects</h3>
                        <p class="card-subtitle">Select a project to view its details.</p>
                    </div>
                </div>

                @if (Model.Projects.Count == 0)
                {
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon">
                            <i class="ti ti-folder-off"></i>
                        </div>

                        <p class="empty-title">No projects found</p>

                        <p class="empty-subtitle text-muted">
                            Add a project from an import drive or change your search query.
                        </p>

                        <div class="empty-action">
                            <a asp-page="./Index"
                               asp-route-ShowCreateProjectModal="true"
                               class="btn btn-primary">
                                <i class="ti ti-plus me-2"></i>
                                Add project
                            </a>
                        </div>
                    </div>
                </div>
                }
                else
                {
                <div class="list-group list-group-flush">
                    @foreach (Project project in Model.Projects)
                    {
                    <partial name="_ProjectView" model="Model.CreateProjectView(project)"/>
                    }
                </div>
                }

                <partial name="_Pagination"
                         model="Model.ProjectPage"
                         view-data='new ViewDataDictionary(ViewData)
                         {
                             ["PageNumberParameter"] = "ProjectPageNumber",
                             ["PageSizeParameter"] = "ProjectPageSize"
                         }'/>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card" id="selected-project-panel">
                @if (Model.SelectedProject is null)
                {
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-icon">
                            <i class="ti ti-click"></i>
                        </div>

                        <p class="empty-title">No project selected</p>

                        <p class="empty-subtitle text-muted">
                            Select a project from the list.
                        </p>
                    </div>
                </div>
                }
                else
                {
                <partial name="_SelectedProjectView" model="Model.CreateSelectedProjectView(Model.SelectedProject)"/>
                }
            </div>
        </div>

    </div>
</div>

<div id="import-progress-card"
     class="card shadow position-fixed top-0 end-0 m-3 d-none"
     style="z-index: 1080; width: 360px;">
    <div class="card-body">
        <div class="d-flex align-items-center mb-2">
            <div class="me-3">
                <span id="import-progress-icon" class="avatar bg-blue-lt">
                    <i class="ti ti-upload"></i>
                </span>
            </div>

            <div class="flex-fill">
                <div id="import-progress-title" class="fw-bold">
                    Importing images
                </div>

                <div id="import-progress-text" class="text-muted small">
                    Starting import...
                </div>
            </div>
        </div>

        <div class="progress progress-sm mb-2">
            <div id="import-progress-bar"
                 class="progress-bar"
                 style="width: 0%"
                 role="progressbar"
                 aria-valuenow="0"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>

        <div class="d-flex justify-content-between text-muted small">
            <span id="import-progress-count">0 / 0 images</span>
            <span id="import-progress-percentage">0%</span>
        </div>
    </div>
</div>

<partial name="/Pages/Projects/_CreateProjectModal.cshtml" model="Model.CreateProjectModal"/>

@section Scripts {

<script src="~/js/create-project-modal.js"></script>
<script src="~/js/import-progress.js"></script>

@if (Model.ShowCreateProjectModal)
{
<script>
    const createProjectModal = new bootstrap.Modal(document.getElementById("create-project-modal"));
    createProjectModal.show();
</script>
}

@if (Model.ShowImportProgress && !string.IsNullOrWhiteSpace(Model.ImportProgressId.ToString()))
{
<script>
    startImportProgress(@Model.ImportProgressTotalFiles, "@Model.ImportProgressId");
</script>
}

<script>
    let initialProjectId = "@Model.SelectedProjectId";

    window.selectProject = async function selectProject(projectId) {
        const panel = document.getElementById("selected-project-panel");
        const url = new URL(window.location);

        const oldProjectId = url.searchParams.get("SelectedProjectId");

        panel.classList.add("opacity-50");

        const response = await fetch(`?handler=SelectedProjectView&projectId=${projectId}`, {
            credentials: "same-origin"
        });

        if (!response.ok) {
            panel.innerHTML = `
                    <div class="card">
                        <div class="card-body">
                            <div class="empty">
                                <p class="empty-title">Could not load project</p>
                            </div>
                        </div>
                    </div>`;

            panel.classList.remove("opacity-50");
            return;
        }

        const selectedProjectInput = document.querySelector('input[name="SelectedProjectId"]');

        if (selectedProjectInput) {
            selectedProjectInput.value = projectId;
        }

        panel.innerHTML = await response.text();
        panel.classList.remove("opacity-50");

        if (!oldProjectId && initialProjectId !== projectId.toString()) {
            await reloadProjectView(initialProjectId, projectId);
        } else if (oldProjectId && oldProjectId !== projectId.toString()) {
            await reloadProjectView(oldProjectId, projectId);
        }

        await reloadProjectView(projectId, projectId);

        url.searchParams.set("SelectedProjectId", projectId);
        window.history.replaceState({}, "", url);
    }

    async function reloadProjectView(projectId, selectedProjectId) {
        const projectView = document.getElementById(`project-view-${projectId}`);

        if (!projectView) {
            return;
        }

        const response = await fetch(
            `?handler=ProjectView&projectId=${projectId}&selectedProjectId=${selectedProjectId}`,
            {
                credentials: "same-origin"
            }
        );

        if (!response.ok) {
            return;
        }

        projectView.outerHTML = await response.text();
    }


    window.openProjectFolder = async function openProjectFolder(projectId) {
        const response = await fetch(`?handler=OpenProjectFolder&selectedProjectId=${projectId}`, {
            credentials: "same-origin"
        });

        if (!response.ok) {
            console.error("Could not open project folder");
        }
    }


    window.openProjectCommandLine = async function openProjectCommandLine(projectId) {
        const response = await fetch(`?handler=OpenProjectCommandLine&selectedProjectId=${projectId}`, {
            credentials: "same-origin"
        });

        if (!response.ok) {
            console.error("Could not open project in command line");
        }
}
</script>
}