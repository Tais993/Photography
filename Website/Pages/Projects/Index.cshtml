@page
@using Domain.entities
@model IndexModel

@{
    ViewData["Title"] = "Projects";
}

<div class="page-body">
    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <div class="page-pretitle">
                    Picture Project Tool
                </div>
                <h2 class="page-title">
                    Projects
                </h2>
                <div class="text-muted mt-1">
                    Browse your photography projects and open one to manage images or selections.
                </div>
            </div>

            <div class="col-auto ms-auto">
                <span class="badge bg-blue-lt">
                    <i class="ti ti-folders me-1"></i>
                    @Model.Projects.Count out of @Model.GetProjectCount() project(s)
                </span>
            </div>
        </div>
    </div>

    <div class="row row-cards mt-3">

        <div class="col-12">
            <form method="get" class="card">
                <div class="card-body">
                    <label class="form-label" asp-for="Search">Search projects</label>

                    <div class="row g-2">
                        @if (Model.SelectedProjectId is not null)
                        {
                            <input type="hidden" asp-for="SelectedProjectId"/>
                        }

                        <div class="col">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="Search"
                                       class="form-control"
                                       placeholder="Search by name..."/>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="ProjectPath"
                                       class="form-control"
                                       placeholder="Search by path..."/>
                            </div>
                        </div>

                        <div class="col-md-1">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="ProjectId"
                                       class="form-control"
                                       type="text"
                                       inputmode="numeric"
                                       pattern="[0-9]*"
                                       placeholder="ID"/>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <input asp-for="EventDate"
                                   type="date"
                                   class="form-control"/>
                        </div>

                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">
                                <i class="ti ti-search me-2"></i>
                                Search
                            </button>
                        </div>

                        <div class="col-auto">
                            <a asp-page="./Index" class="btn btn-outline-secondary">
                                Reset
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <div>
                        <h3 class="card-title">All projects</h3>
                        <p class="card-subtitle">Select a project to view its details.</p>
                    </div>
                </div>

                @if (Model.Projects.Count == 0)
                {
                    <div class="card-body">
                        <div class="empty">
                            <div class="empty-icon">
                                <i class="ti ti-folder-off"></i>
                            </div>

                            <p class="empty-title">No projects found</p>

                            <p class="empty-subtitle text-muted">
                                Try changing your search query.
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (Project project in Model.Projects)
                        {
                            <partial name="_ProjectView" model="Model.CreateProjectView(project)"/>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card" id="selected-project-panel">
                @if (Model.SelectedProject is null)
                {
                    <div class="card-body">
                        <div class="empty">
                            <div class="empty-icon">
                                <i class="ti ti-click"></i>
                            </div>

                            <p class="empty-title">No project selected</p>

                            <p class="empty-subtitle text-muted">
                                Select a project from the list.
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <partial name="_SelectedProjectView" model="Model.SelectedProject"/>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {

    <script>
        let initialProjectId = "@Model.SelectedProjectId";
        
        window.selectProject = async function selectProject(projectId) {
            const panel = document.getElementById("selected-project-panel");
            const url = new URL(window.location);

            const oldProjectId = url.searchParams.get("SelectedProjectId");
            
            panel.classList.add("opacity-50");

            const response = await fetch(`?handler=SelectedProjectView&projectId=${projectId}`, {
                credentials: "same-origin"
            });

            if (!response.ok) {
                panel.innerHTML = `
                    <div class="card">
                        <div class="card-body">
                            <div class="empty">
                                <p class="empty-title">Could not load project</p>
                            </div>
                        </div>
                    </div>`;

                panel.classList.remove("opacity-50");
                return;
            }

            const selectedProjectInput = document.querySelector('input[name="SelectedProjectId"]');

            if (selectedProjectInput) {
                selectedProjectInput.value = projectId;
            }

            panel.innerHTML = await response.text();
            panel.classList.remove("opacity-50");

            if (!oldProjectId && initialProjectId !== projectId.toString()) {
                await reloadProjectView(initialProjectId, projectId);
            } else if (oldProjectId && oldProjectId !== projectId.toString()) {
                await reloadProjectView(oldProjectId, projectId);
            } 

            await reloadProjectView(projectId, projectId);

            url.searchParams.set("SelectedProjectId", projectId);
            window.history.replaceState({}, "", url);
        }

        async function reloadProjectView(projectId, selectedProjectId) {
            const projectView = document.getElementById(`project-view-${projectId}`);

            if (!projectView) {
                return;
            }

            const response = await fetch(
                `?handler=ProjectView&projectId=${projectId}&selectedProjectId=${selectedProjectId}`,
                {
                    credentials: "same-origin"
                }
            );

            if (!response.ok) {
                return;
            }

            projectView.outerHTML = await response.text();
        }
    </script>
}

