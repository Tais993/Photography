@model Domain.website.SelectedProjectViewModel

<div class="card-header">
    <div>
        <h3 class="card-title">@Model.Project.Name</h3>
        <p class="card-subtitle">Selected project</p>
    </div>

    <div class="card-actions">
        <span class="badge bg-green-lt">
            <i class="ti ti-check me-1"></i>
            Active
        </span>
    </div>
</div>

<div class="card-body">
    <div class="datagrid">

        <div class="row">
            <div class="col-md-6">
                <div class="datagrid-item">
                    <div class="datagrid-title">Id</div>
                    <div class="datagrid-content">@Model.Project.Id</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="datagrid-item">
                    <div class="datagrid-title">Name</div>
                    <div class="datagrid-content">@Model.Project.Name</div>
                </div>
            </div>
        </div>

        <div class="row">
            @if (Model.Project.ParentProjectId is not null)
            {
                <div class="col-md-6">
                    <div class="datagrid-item">
                        <div class="datagrid-title">Parent project ID</div>
                        <div class="datagrid-content">@Model.Project.ParentProjectId</div>
                    </div>
                </div>
            }

            <div class="col-md-6">
                <div class="datagrid-item">
                    <div class="datagrid-title">Event date</div>
                    <div class="datagrid-content">
                        @Model.Project.EventDate.ToString("yyyy-MM-dd")
                    </div>
                </div>
            </div>
        </div>

        <div class="datagrid-item">
            <div class="datagrid-title">Path</div>
            <div class="datagrid-content text-break">
                @Model.Project.Path
            </div>
        </div>
    </div>
</div>

<div class="card-footer">
    <div class="d-grid gap-2">
        @if (Model.CanOpenInImageViewer)
        {
            <button type="button"
                    class="btn btn-primary"
                    onclick="openProjectFolder(@Model.Project.Id)">
                <i class="ti ti-photo me-2"></i>
                Open images in @Model.ImageViewerName
            </button>
        }
        <button type="button"
                class="btn btn-primary"
                onclick="openProjectFolder(@Model.Project.Id)">
            <i class="ti ti-photo me-2"></i>
            Open images in @Model.ImageViewerName
        </button>

        <a asp-page="/Selection/Index"
           asp-route-SelectedProjectId="@Model.Project.Id"
           class="btn btn-outline-primary">
            <i class="ti ti-checkbox me-2"></i>
            Open selection
        </a>
    </div>
</div>