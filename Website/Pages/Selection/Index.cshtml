@page
@using Domain.entities
@model IndexModel

@{
    ViewData["Title"] = "Projects";
}

<div class="page-body">
    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <div class="page-pretitle">
                    Picture Project Tool
                </div>
                <h2 class="page-title">
                    Pictures
                </h2>
                <div class="text-muted mt-1">
                    Browse your project's pictures and select them accordingly.
                </div>
            </div>

            <div class="col-auto ms-auto">
                <span class="badge bg-blue-lt">
                    <i class="ti ti-folders me-1"></i>
                    @Model.Images.Count out of @Model.GetProjectImageCount() image(s)
                </span>
            </div>
        </div>
    </div>

    <div class="row row-cards mt-3">
        <div class="col-12">
            <form method="get" class="card" id="search-form">
                <div class="card-body">
                    <label class="form-label" asp-for="Search">Search images</label>

                    <div class="row g-2">
                        <input type="hidden" asp-for="SelectedProjectId"/>
                        <input type="hidden" asp-for="SelectedImageId"/>

                        <div class="col">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="Search"
                                       class="form-control"
                                       placeholder="Search by name..."/>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <select asp-for="FolderName" class="form-select">
                                <option value="">All folders</option>
                                <option value="Original">Original</option>
                                <option value="Originals">Originals</option>
                                <option value="Editing">Editing</option>
                                <option value="Final">Final</option>
                                <option value="Finals">Finals</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <select asp-for="FileType" class="form-select">
                                <option value="">All types</option>
                                <option value=".jpg">JPG</option>
                                <option value=".jpeg">JPEG</option>
                                <option value=".png">PNG</option>
                                <option value=".nef">NEF</option>
                                <option value=".raw">RAW</option>
                            </select>
                        </div>

                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">
                                <i class="ti ti-search me-2"></i>
                                Search
                            </button>
                        </div>

                        <div class="col-auto">
                            <div class="col-auto">
                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        onclick="resetFilters()">
                                    Reset
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <div>
                        <h3 class="card-title">All images</h3>
                        <p class="card-subtitle">Select an image to view its details.</p>
                    </div>
                </div>

                <div class="card-body">

                    @if (Model.Images.Count == 0)
                    {
                        <div class="empty">
                            <div class="empty-icon">
                                <i class="ti ti-photo-off"></i>
                            </div>

                            <p class="empty-title">No images found</p>

                            <p class="empty-subtitle text-muted">
                                Try changing your search query.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="row row-cards">
                            @foreach (Image image in Model.GetImages())
                            {
                                bool isSelected = Model.SelectedImageIds.Contains(image.Id!.Value);

                                _ImageView imageView = new _ImageView()
                                {
                                    Selected = isSelected,
                                    ImageId = image.Id,
                                    FileType = image.FileType,
                                    FileName = image.FileName,
                                    RelationalFilePath = image.RelationalFilePath
                                };
                                <partial name="_ImageView" model="imageView"/>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>

        <div class="col-lg-5">

            <div id="selected-image-panel">
                @if (Model.SelectedImageId is null)
                {
                    <div class="card">
                        <div class="card-body">
                            <div class="empty">
                                <div class="empty-icon">
                                    <i class="ti ti-click"></i>
                                </div>

                                <p class="empty-title">No image selected</p>

                                <p class="empty-subtitle text-muted">
                                    Select an image from the list.
                                </p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <partial name="_SelectedImage" model="Model.SelectedImage"/>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .image-hover-button {
        opacity: 0;
        transition: opacity 120ms ease;
        z-index: 2;
    }

    .image-hover-area:hover .image-hover-button {
        opacity: 1;
    }
</style>

@section Scripts {
    <script>
        async function openImageInIrfanView() {
            const selectedProjectId = document.querySelector('input[name="SelectedProjectId"]')?.value;
            const selectedImageId = document.querySelector('input[name="SelectedImageId"]')?.value;

            await fetch(`?handler=OpenImage&SelectedProjectId=${selectedProjectId}&SelectedImageId=${selectedImageId}`, {});
        }

        window.selectImage = async function selectImage(imageId) {
            const panel = document.getElementById("selected-image-panel");

            panel.classList.add("opacity-50");

            const response = await fetch(`?handler=SelectedImage&imageId=${imageId}`);

            if (!response.ok) {
                panel.innerHTML = `
            <div class="card">
                <div class="card-body">
                    <div class="empty">
                        <p class="empty-title">Could not load image</p>
                    </div>
                </div>
            </div>`;
                panel.classList.remove("opacity-50");
                return;
            }

            const selectedImageInput = document.querySelector('input[name="SelectedImageId"]');

            if (selectedImageInput) {
                selectedImageInput.value = imageId;
            }

            const url = new URL(window.location);
            url.searchParams.set("SelectedImageId", imageId);
            window.history.replaceState({}, "", url);

            panel.innerHTML = await response.text();
            panel.classList.remove("opacity-50");
        }

        window.resetFilters = function () {
            const selectedProjectId = document.querySelector('input[name="SelectedProjectId"]')?.value;
            const selectedImageId = document.querySelector('input[name="SelectedImageId"]')?.value;

            const url = new URL(window.location);

            url.search = "";

            if (selectedProjectId) {
                url.searchParams.set("SelectedProjectId", selectedProjectId);
            }

            if (selectedImageId) {
                url.searchParams.set("SelectedImageId", selectedImageId);
            }

            window.location.href = url.toString();
        }
        
        window.toggleImageSelection = async function toggleImageSelection(event, button) {
            event.stopPropagation();
            event.preventDefault();

            const imageId = button.dataset.imageId;
            const projectId = document.querySelector("[name='SelectedProjectId']").value;


            console.log(`image-view-${imageId}`);
            const imageView = document.getElementById(`image-view-${imageId}`);

            const response = await fetch(`?handler=ToggleImageSelection&imageId=${imageId}&selectedProjectId=${projectId}`);

            if (!response.ok) {
                console.error("Could not toggle image selection");
                return;
            }

            imageView.outerHTML = await response.text();
        }

        document.getElementById("search-form").addEventListener("submit", function () {
            for (const element of this.querySelectorAll("input[name], select[name]")) {
                if (!element.value) {
                    element.disabled = true;
                }
            }
        });

    </script>
}