@page
@using Domain.entities
@using Constants = Application.Constants
@model IndexModel

@{
    ViewData["Title"] = "Projects";
}

<div class="page-body">

    <div class="page-header d-print-none">
        <div class="row align-items-center">
            <div class="col">
                <div class="page-pretitle">
                    Picture Project Tool
                </div>
                <h2 class="page-title">
                    Pictures
                </h2>
                <div class="text-muted mt-1">
                    Browse your project's pictures and select them accordingly.
                </div>
            </div>

            <div class="col-auto ms-auto">
            <span class="badge bg-blue-lt">
                <i class="ti ti-folders me-1"></i>
                @Model.Images.Count out of @Model.GetProjectImageCount() image(s)
            </span>
            </div>
        </div>
    </div>

    <div class="row row-cards mt-3">

        <div class="col-12">
            <form method="get" class="card">
                <div class="card-body">
                    <label class="form-label" asp-for="Search">Search images</label>
                    
                    <div class="row g-2">
                        <input type="hidden" asp-for="SelectedProjectId" />

                        <div class="col">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-search"></i>
                                </span>

                                <input asp-for="Search"
                                       class="form-control"
                                       placeholder="Search by name..."/>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <select asp-for="FolderName" class="form-select">
                                <option value="">All folders</option>
                                <option value="Original">Original</option>
                                <option value="Originals">Originals</option>
                                <option value="Editing">Editing</option>
                                <option value="Final">Final</option>
                                <option value="Finals">Finals</option>
                            </select>
                        </div>
                        
                        
                        <div class="col-md-2">
                            <select asp-for="FileType" class="form-select">
                                <option value="">All types</option>
                                <option value=".jpg">JPG</option>
                                <option value=".jpeg">JPEG</option>
                                <option value=".png">PNG</option>
                                <option value=".nef">NEF</option>
                                <option value=".raw">RAW</option>
                            </select>
                        </div>
                        
                        
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">
                                <i class="ti ti-search me-2"></i>
                                Search
                            </button>
                        </div>

                        <div class="col-auto">
                            <a asp-page="./Index"
                               asp-route-selectedProjectId="@Model.SelectedProjectId"
                               class="btn btn-outline-secondary">
                                Reset
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <div>
                        <h3 class="card-title">All images</h3>
                        <p class="card-subtitle">Select an image to view its details.</p>
                    </div>
                </div>

                <div class="card-body">

                    @if (Model.Images.Count == 0)
                    {
                        <div class="empty">
                            <div class="empty-icon">
                                <i class="ti ti-photo-off"></i>
                            </div>

                            <p class="empty-title">No images found</p>

                            <p class="empty-subtitle text-muted">
                                Try changing your search query.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="row row-cards">
                            @foreach (Image image in Model.HideNefFilesWhenJpgExists())
                            {
                                bool isSelected = Model.SelectedImageIds.Contains(image.Id!.Value);

                                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                    <a asp-page="./Index"
                                       asp-route-SelectedProjectId="@Model.SelectedProjectId"
                                       asp-route-SelectedImageId="@image.Id"
                                       asp-route-search="@Model.Search"
                                       class="card card-sm text-decoration-none @(isSelected ? "border-primary" : "")">

                                        <div class="position-relative">
                                            <div class="ratio ratio-1x1">
                                                @if (Constants.ImageFileTypes.Contains(image.FileType))
                                                {
                                                    <img src="@Url.Page("/Selection/Thumbnail", new
                                                              {
                                                                  imageId = image.Id
                                                              })"
                                                         alt="@image.FileName"
                                                         class="card-img-top object-fit-cover"/>
                                                }
                                                else
                                                {
                                                    <div
                                                        class="d-flex align-items-center justify-content-center bg-blue-lt">
                                                        <i class="ti ti-photo fs-1 text-blue"></i>
                                                    </div>
                                                }
                                            </div>

                                            @if (isSelected)
                                            {
                                                <span class="badge bg-primary position-absolute top-0 start-0 m-2">
                                        <i class="ti ti-check"></i>
                                    </span>
                                            }
                                        </div>

                                        <div class="card-body p-2">
                                            <div class="text-truncate fw-bold">
                                                @image.FileName
                                            </div>

                                            <div class="text-muted small text-truncate">
                                                @image.FileType
                                            </div>

                                            <div class="text-muted small text-truncate">
                                                @image.RelationalFilePath
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card">
                @if (Model.SelectedImageId is null)
                {
                    <div class="card-body">
                        <div class="empty">
                            <div class="empty-icon">
                                <i class="ti ti-click"></i>
                            </div>

                            <p class="empty-title">No image selected</p>

                            <p class="empty-subtitle text-muted">
                                Select an image from the list.
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-header">
                        <div>
                            <h3 class="card-title">@Model.SelectedImage.FileName</h3>
                            <p class="card-subtitle">Selected image</p>
                        </div>

                        <div class="card-actions">
                        <span class="badge bg-green-lt">
                            <i class="ti ti-check me-1"></i>
                            Active
                        </span>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="datagrid">
                            <div class="datagrid-item">
                                <div class="datagrid-title">Path</div>
                                <div class="datagrid-content text-break">
                                    @Model.SelectedImage.RelationalFilePath
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="position-relative">
                        <div class="ratio ratio-1x1">
                            @if (Constants.ImageFileTypes.Contains(Model.SelectedImage.FileType))
                            {
                                <img src="@Url.Page("/Selection/Thumbnail", new
                                          {
                                              imageId = Model.SelectedImage.Id
                                          })"
                                     alt="@Model.SelectedImage.FileName"
                                     class="card-img-top object-fit-cover"/>
                            }
                            else
                            {
                                <div
                                    class="d-flex align-items-center justify-content-center bg-blue-lt">
                                    <i class="ti ti-photo fs-1 text-blue"></i>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="d-grid gap-2">
                            <button type="button"
                                    class="btn btn-primary"
                                    onclick="openImageInIrfanView()">
                                <i class="ti ti-photo me-2"></i>
                                Open image in Irfanview
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        async function openImageInIrfanView() {
            await fetch(`?handler=OpenImage&SelectedProjectId=@Model.SelectedProjectId&SelectedImageId=@Model.SelectedImageId`, {});
        }
    </script>
}