<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] - Website</title>
  <script type="importmap"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@latest/dist/css/tabler.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/dist/tabler-icons.min.css"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
  <link rel="stylesheet" href="~/Website.styles.css" asp-append-version="true"/>
</head>
<body>
@{
  string? currentPage = ViewContext.RouteData.Values["Page"]?.ToString();

  string IsActive(string page)
  {
    return currentPage == page ? "active" : "";
  }

  string IsActiveSection(string section)
  {
    return currentPage != null && currentPage.StartsWith(section)
      ? "active"
      : "";
  }
}

<header class="navbar navbar-expand-md d-print-none">
  <div class="container-xl">
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbar-menu"
      aria-controls="navbar-menu"
      aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <ul class="navbar-nav">
      <li class="nav-item @IsActive("/Index")">
        <a class="nav-link" asp-page="/Index">
          <span class="nav-link-title">Home</span>
        </a>
      </li>

      <li class="nav-item @IsActiveSection("/Projects")">
        <a class="nav-link" asp-page="/Projects/Index">
          <span class="nav-link-title">Projects</span>
        </a>
      </li>

      <li class="nav-item @IsActiveSection("/Selection")">
        <a class="nav-link" asp-page="/Selection/Index">
          <span class="nav-link-title">Selection</span>
        </a>
      </li>
    </ul>
    
    <!--
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" href="#">
          <span class="nav-link-title"> Home </span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="../Projects/">
          <span class="nav-link-title"> Projects </span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" asp-page="/Selection">
          <span class="nav-link-title"> Selection </span>
        </a>
      </li>
    </ul>
    -->
  </div>
</header>
<div class="container">
  <main role="main" class="pb-3">
    @RenderBody()
  </main>
</div>

<footer class="border-top footer text-muted">
  <div class="container">
    &copy; 2026 - Website - <a asp-area="" asp-page="/Privacy">Privacy</a>
  </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/@@tabler/core@latest/dist/js/tabler.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>